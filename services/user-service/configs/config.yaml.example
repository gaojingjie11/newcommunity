service:
  name: user-service
  host: 0.0.0.0
  port: 8001
  register_ip: YOUR_SERVICE_REGISTER_IP

mysql:
  host: YOUR_INFRA_SERVER_IP
  port: 3306
  database: smart_community
  username: root
  password: YOUR_MYSQL_PASSWORD

redis:
  host: YOUR_INFRA_SERVER_IP
  port: 6379
  password: YOUR_REDIS_PASSWORD

nacos:
  enabled: true
  host: YOUR_INFRA_SERVER_IP
  port: 8848
  namespace: public
  group: DEFAULT_GROUP

rabbitmq:
  host: YOUR_INFRA_SERVER_IP
  port: 5672
  username: guest
  password: guest

minio:
  endpoint: YOUR_INFRA_SERVER_IP:9000
  access_key: minioadmin
  secret_key: YOUR_MINIO_PASSWORD
  bucket: smart-community

agent:
  base_url: http://agent-service:9000
  llm_api_key: ""
  llm_base_url: ""
  llm_model: ""
