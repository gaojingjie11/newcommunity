COMPOSE_PARALLEL_LIMIT=1
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_FACEBODY_ENDPOINT=facebody.cn-shanghai.aliyuncs.com

# =========================================================================
# 智慧社区大模型配置 (请在此处配置各个功能所使用的大模型 API 密钥、URL 和模型名称)
# =========================================================================
# 1. 全局默认大模型配置（若下面的子项模型未单独配置，则会自动回退并使用此处的全局配置）
LLM_API_KEY=your_global_llm_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# 2. 社区通用对话与历史摘要总结模型 (ChatDefault)
LLM_CHAT_DEFAULT_API_KEY=
LLM_CHAT_DEFAULT_BASE_URL=
LLM_CHAT_DEFAULT_MODEL=mimo-v2.5

# 3. 智能物业/商超 ReAct Agent 推理与工具执行模型 (AgentReasoning)
LLM_AGENT_REASONING_API_KEY=
LLM_AGENT_REASONING_BASE_URL=
LLM_AGENT_REASONING_MODEL=mimo-v2.5-pro

# 4. 垃圾分类图像识别视觉大模型 (ImageVision)
LLM_IMAGE_VISION_API_KEY=
LLM_IMAGE_VISION_BASE_URL=
LLM_IMAGE_VISION_MODEL=

# 5. 语音识别与合成大模型 (ASR / TTS)
LLM_ASR_API_KEY=
LLM_ASR_BASE_URL=
LLM_ASR_MODEL=mimo-v2.5-asr
LLM_TTS_API_KEY=
LLM_TTS_BASE_URL=
LLM_TTS_MODEL=mimo-v2.5-tts

# 6. RAG 向量化模型 (Doubao Embedding / ARK)
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215
# =========================================================================
# SMTP 邮件服务配置 (用于支付成功和余额充值异步邮件通知)
# =========================================================================
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your_qq_email@qq.com
SMTP_PASSWORD=eksiwbvjhgfkdhec
SMTP_FROM_ADDRESS=your_qq_email@qq.com
SMTP_FROM_NAME=智慧社区管理员
SMTP_USE_TLS=true
